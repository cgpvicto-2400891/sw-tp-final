# ============================================================
#  VARIABLES D'ENVIRONNEMENT — copier dans Render > Environment
# ============================================================

# Environnement : development (local) ou production (Render)
NODE_ENV=production

# --- BASE DE DONNÉES RENDER ---
# Utiliser l'« Internal Database URL » de votre BD Render
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE

# --- SSL (obligatoire sur Render) ---
PG_SSL=true

# -------------------------------------------------------
# Variables utilisées UNIQUEMENT en développement LOCAL
# (laisser vides sur Render — DATABASE_URL suffit)
# -------------------------------------------------------
# PG_USER=postgres
# PG_HOST=localhost
# PG_DATABASE=biblio
# PG_PASSWORD=1234
# PG_PORT=5432
