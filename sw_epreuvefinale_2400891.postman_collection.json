{
    "info": {
        "name": "sw_épreuvefinale_2400891",
        "description": "Collection Postman PRO — Épreuve finale Services Web Hiver 2026\n\n**IMPORTANT** :\n1. Exécutez d'abord la requête **« Étape 1 : Créer une bibliothèque (Générer Clé API) »**.\n2. La clé API générée sera **automatiquement sauvegardée** dans les variables de la collection.\n3. Vous pourrez ensuite exécuter toutes les autres requêtes sans rien configurer manuellement.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "https://sw-tp-final.onrender.com",
            "type": "string"
        },
        {
            "key": "cle_api",
            "value": "",
            "type": "string"
        },
        {
            "key": "livre_id",
            "value": "",
            "type": "string"
        },
        {
            "key": "pret_id",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "1. AUTHENTIFICATION",
            "item": [
                {
                    "name": "Étape 1 : Créer une bibliothèque (Générer Clé API)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const response = pm.response.json();",
                                    "if (response.succes && response.donnees.cle_api) {",
                                    "    pm.collectionVariables.set(\"cle_api\", response.donnees.cle_api);",
                                    "    console.log(\"Clé API enregistrée automatiquement : \", response.donnees.cle_api);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{base_url}}/api/bibliotheques",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"nom\": \"Bibliothèque DA 2400891\",\n  \"courriel\": \"admin_{{$timestamp}}@biblio.ca\",\n  \"mot_de_passe\": \"P@ssword123\"\n}"
                        }
                    }
                },
                {
                    "name": "Étape 2 (Facultatif) : Récupérer / Régénérer Clé API",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const response = pm.response.json();",
                                    "if (response.succes && response.donnees.cle_api) {",
                                    "    pm.collectionVariables.set(\"cle_api\", response.donnees.cle_api);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{base_url}}/api/bibliotheques/cle-api",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"courriel\": \"admin@biblio.ca\",\n  \"mot_de_passe\": \"P@ssword123\",\n  \"regenerer\": false\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "2. LIVRES",
            "item": [
                {
                    "name": "Ajouter un livre",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const response = pm.response.json();",
                                    "if (response.succes) {",
                                    "    pm.collectionVariables.set(\"livre_id\", 1); // Raccourci temporaire (l'API ne renvoie pas l'ID en POST)",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "cle_api {{cle_api}}"
                            }
                        ],
                        "url": "{{base_url}}/api/livres",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"titre\": \"L'Alchimiste {{$randomInt}}\",\n  \"auteur\": \"Paulo Coelho\",\n  \"isbn\": \"978-2-0814-1181-{{$randomInt}}\",\n  \"description\": \"Un roman initiatique sur la poursuite de ses rêves.\"\n}"
                        }
                    }
                },
                {
                    "name": "Lister les livres (Disponibles uniquement)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "cle_api {{cle_api}}"
                            }
                        ],
                        "url": "{{base_url}}/api/livres"
                    }
                },
                {
                    "name": "Lister TOUS les livres (tous=true)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "cle_api {{cle_api}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/livres?tous=true",
                            "query": [
                                {
                                    "key": "tous",
                                    "value": "true"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Détail d'un livre",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "cle_api {{cle_api}}"
                            }
                        ],
                        "url": "{{base_url}}/api/livres/1"
                    }
                },
                {
                    "name": "Modifier un livre",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "cle_api {{cle_api}}"
                            }
                        ],
                        "url": "{{base_url}}/api/livres/1",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"titre\": \"L'Alchimiste (Édition Illustrée)\",\n  \"auteur\": \"Paulo Coelho\",\n  \"isbn\": \"978-2-0814-1181-0\",\n  \"description\": \"Version illustrée mise à jour.\"\n}"
                        }
                    }
                },
                {
                    "name": "Modifier statut du livre",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "cle_api {{cle_api}}"
                            }
                        ],
                        "url": "{{base_url}}/api/livres/1/statut",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"statut\": \"emprunte\"\n}"
                        }
                    }
                },
                {
                    "name": "Supprimer un livre",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "cle_api {{cle_api}}"
                            }
                        ],
                        "url": "{{base_url}}/api/livres/999"
                    }
                }
            ]
        },
        {
            "name": "3. PRÊTS",
            "item": [
                {
                    "name": "Ajouter un prêt",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const response = pm.response.json();",
                                    "if (response.succes) {",
                                    "    pm.collectionVariables.set(\"pret_id\", 1);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "cle_api {{cle_api}}"
                            }
                        ],
                        "url": "{{base_url}}/api/livres/1/prets",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"nom_emprunteur\": \"Alexandre Dupont\",\n  \"date_debut\": \"2026-05-01\",\n  \"date_retour_prevue\": \"2026-05-15\"\n}"
                        }
                    }
                },
                {
                    "name": "Modifier un prêt",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "cle_api {{cle_api}}"
                            }
                        ],
                        "url": "{{base_url}}/api/prets/1",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"nom_emprunteur\": \"Alexandre Dupont\",\n  \"date_debut\": \"2026-05-01\",\n  \"date_retour_prevue\": \"2026-05-30\"\n}"
                        }
                    }
                },
                {
                    "name": "Terminer un prêt (Changer statut)",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "cle_api {{cle_api}}"
                            }
                        ],
                        "url": "{{base_url}}/api/prets/1/statut",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"statut\": \"termine\"\n}"
                        }
                    }
                },
                {
                    "name": "Supprimer un prêt",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "cle_api {{cle_api}}"
                            }
                        ],
                        "url": "{{base_url}}/api/prets/999"
                    }
                }
            ]
        }
    ]
}